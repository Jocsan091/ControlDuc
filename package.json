{
  "name": "controldoc",
  "version": "1.0.0",
  "description": "Sistema de gestión de asistencia docente",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "Rodrigo Demonte",
  "license": "ISC",
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.rodrigodemonte.controldoc",
    "productName": "ControlDoc",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/img/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ControlDoc"
    }
  }
}
